# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4

# Neo4j Configuration
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password_here

# Vector Store Configuration
CHROMADB_COLLECTION_NAME=architecture_reviews
CHROMADB_PERSIST_DIR=./memory/embeddings_cache

# System Configuration
LOG_LEVEL=INFO
SUBMISSION_INTAKE_PATH=./submissions/incoming
VALIDATED_SUBMISSION_PATH=./submissions/validated
ARCHIVED_SUBMISSION_PATH=./submissions/archived

# Review Configuration
APPROVAL_THRESHOLD=0.75
WARNING_THRESHOLD=0.50
